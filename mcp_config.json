{
  "mcpServers": {
    "miot-mcp": {
      "type": "stdio",
      "command": "python",
      "args": ["-m", "miot_mcp"],
      "env": {
        "MIOT_CACHE_DIR": "~/.miot-mcp"
      }
    },
    "miot-mcp-remote": {
      "type": "sse",
      "url": "${XIAOZHI_MCP_URL}",
      "disabled": true
    }
  }
}
